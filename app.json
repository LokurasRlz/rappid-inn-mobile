{
  "expo": {
    "name": "Market House",
    "slug": "market-house",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "markethouse",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F0E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tuempresa.markethouse",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la camara para escanear codigos de barras y QR.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para actualizar tu perfil."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F6F0E5"
      },
      "package": "com.tuempresa.markethouse",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Market House",
      "shortName": "MARKET HOUSE",
      "description": "Tu mercado de confianza para acceso, compra y salida con QR.",
      "themeColor": "#234936",
      "backgroundColor": "#F6F0E5"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acceso a la camara para escanear productos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "TU-EAS-PROJECT-ID"
      },
      "apiBaseUrl": "http://192.168.68.59:3000/api/v1",
      "googleClientId": "TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
      "mpPublicKey": "TEST-TU-MP-PUBLIC-KEY"
    }
  }
}
